#first one
class Elevator:
    def __init__(self, bottom, top):
        self.bottom = bottom
        self.top = top
        self.current = bottom

    def floor_up(self):
        if self.current < self.top:
            self.current += 1
            print(f"đang ở tầng {self.current}")
        else:
            print("bên trên tầng lầu")

    def floor_down(self):
        if self.current > self.bottom:
            self.current -= 1
            print(f"đang ở tầng {self.current}")
        else:
            print("xuống chót rồi ba😅")

    def go_to_floor(self, floor):
        if floor < self.bottom or floor > self.top:
            print("did that floor really exist?")
            return
        while self.current < floor:
            self.floor_up()
        while self.current > floor:
            self.floor_down()
#second one
class Building:
    def __init__(self, bottom, top, num_elevators):
        self.bottom = bottom
        self.top = top
        self.elevators = [Elevator(bottom, top) for _ in range(num_elevators)]

    def run_elevator(self, elevator_number, destination_floor):
        if 0 <= elevator_number < len(self.elevators):
            self.elevators[elevator_number].go_to_floor(destination_floor)
        else:
            print("that dont exist!")
    #third one
    def fire_alarm(self):
        for elevator in self.elevators:
            elevator.go_to_floor(self.bottom)

